{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "quick-notes",
  "title": "Quick Notes",
  "description": "Unlimited local notes with Markdown support - a Raycast Notes alternative without limits",
  "icon": "icon.png",
  "author": "crush",
  "categories": ["Productivity"],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Search Notes",
      "description": "Browse and search all your notes",
      "mode": "view"
    },
    {
      "name": "create-note",
      "title": "Create Note",
      "description": "Quickly create a new note",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.100.0",
    "@raycast/utils": "^1.19.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.14.0",
    "@types/react": "19.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
